# c64_cse.cfg — Production linker config for CSE
#
# Generated by compute_layout.py from c64_trial.cfg measurements.
# CODE+RODATA load after the LOADER in the PRG file but run at
# @@RUNTIME_START@@ in high memory.  The loader copies them at boot.
#
# DO NOT EDIT — regenerated on every build.

MEMORY {
    ZP:       file = "",  define = yes, start = $0002,            size = $007E;
    LOADADDR: file = %O,               start = $0801 - 2,        size = $0002;
    HEADER:   file = %O,  define = yes, start = $0801,           size = $000C;
    LOADIMG:  file = %O,  define = yes, start = __HEADER_LAST__, size = $D000 - __HEADER_LAST__;
    RUNTIME:  file = "",               start = @@RUNTIME_START@@, size = $D000 - @@RUNTIME_START@@;
    BSS:      file = "",               start = @@BSS_START@@,     size = $D000 - @@BSS_START@@;
    KDATA:    file = "",               start = $F100,            size = $0EFA;
}
SEGMENTS {
    ZEROPAGE: load = ZP,       type = zp;
    LOADADDR: load = LOADADDR, type = ro;
    EXEHDR:   load = HEADER,   type = ro;
    LOADER:   load = LOADIMG,  type = ro,  define = yes;
    CODE:     load = LOADIMG,  run = RUNTIME, type = ro, define = yes;
    RODATA:   load = LOADIMG,  run = RUNTIME, type = ro, define = yes;
    KDATA:    load = LOADIMG,  run = KDATA,   type = ro, define = yes;
    DATA:     load = LOADIMG,  run = RUNTIME, type = rw;
    BSS:      load = BSS,      type = bss, define = yes;
}
